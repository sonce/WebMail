@page
@model WebMail.Pages.OAuth.CallbackModel
@{
    ViewData["Title"] = L["OAuth.Callback.Title"].Value;
}

<h1 class="display-6">@L["OAuth.Callback.Title"]</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-warning" role="alert">@Model.ErrorMessage</div>
}
else
{
    <div class="alert alert-success" role="alert">@L["OAuth.Success"]</div>
}

@if (!string.IsNullOrEmpty(Model.Card))
{
    <a class="btn btn-primary" asp-page="/Buyer/Email" asp-route-card="@Model.Card">@L["OAuth.BackToStatus"]</a>
}
