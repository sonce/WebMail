@page
@using WebMail.Domain
@model WebMail.Pages.Sales.BuyersModel
@{
    ViewData["Title"] = L["Sales.Buyers.Title"].Value;
}

<h1 class="display-6">@L["Sales.Buyers.Title"]</h1>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-info" role="alert">@Model.Message</div>
}

@if (Model.Buyers.Count == 0)
{
    <p>@L["Common.NoBuyers"]</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>@L["Table.CardNo"]</th>
                <th>@L["Table.EmailStatus"]</th>
                <th>@L["Table.BuyerStatus"]</th>
                <th>@L["Table.SupplierProcessingStatus"]</th>
                <th>@L["Table.CreatedAt"]</th>
                <th>@L["Table.Operations"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var buyer in Model.Buyers)
            {
                <tr>
                    <td>@buyer.CardNo</td>
                    <td>@buyer.EmailStatus</td>
                    <td>@buyer.BuyerStatus</td>
                    <td><partial name="_SupplierStatusBadge" model="buyer.SupplierStatus" /></td>
                    <td>@buyer.CreatedAt</td>
                    <td>
                        <form method="post" asp-page-handler="Delete">
                            <input type="hidden" name="id" value="@buyer.Id" />
                            <button type="submit" class="btn btn-sm btn-danger">@L["Common.Delete"]</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
