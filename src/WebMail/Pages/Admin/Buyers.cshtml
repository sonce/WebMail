@page
@using WebMail.Domain
@model WebMail.Pages.Admin.BuyersModel
@{
    ViewData["Title"] = L["Admin.Buyers.Title"].Value;
}

<h1 class="display-6">@L["Admin.Buyers.Title"]</h1>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-info" role="alert">@Model.Message</div>
}

<form method="get" class="row g-2 mb-3">
    <div class="col-auto">
        <select class="form-select" asp-for="StatusFilter"
                asp-items="Html.GetEnumSelectList<WebMail.Domain.BuyerStatus>()">
            <option value="">@L["Filter.AllBuyerStatus"]</option>
        </select>
    </div>
    <div class="col-auto">
        <select class="form-select" asp-for="EmailFilter"
                asp-items="Html.GetEnumSelectList<WebMail.Domain.EmailAuthorizationStatus>()">
            <option value="">@L["Filter.AllEmailStatus"]</option>
        </select>
    </div>
    <div class="col-auto">
        <input class="form-control" asp-for="CardNo" placeholder="@L["Filter.CardKeyword"]" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary">@L["Common.Filter"]</button>
        <a class="btn btn-outline-secondary" asp-page="/Admin/Buyers">@L["Common.Reset"]</a>
    </div>
</form>

@if (Model.Buyers.Count == 0)
{
    <p>@L["Common.NoBuyers"]</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>@L["Table.CardNo"]</th>
                <th>@L["Table.EmailStatus"]</th>
                <th>@L["Table.BuyerStatus"]</th>
                <th>@L["Table.SupplierStatus"]</th>
                <th>@L["Table.CreatedAt"]</th>
                <th>@L["Table.Operations"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var buyer in Model.Buyers)
            {
                <tr>
                    <td>@buyer.CardNo</td>
                    <td>@buyer.EmailStatus</td>
                    <td>@buyer.BuyerStatus</td>
                    <td><partial name="_SupplierStatusBadge" model="buyer.SupplierStatus" /></td>
                    <td>@buyer.CreatedAt</td>
                    <td>
                        @if (buyer.BuyerStatus == BuyerStatus.PendingReview)
                        {
                            <div class="d-flex gap-2">
                                <form method="post" asp-page-handler="Approve">
                                    <input type="hidden" name="id" value="@buyer.Id" />
                                    <button type="submit" class="btn btn-sm btn-success">@L["Action.Approve"]</button>
                                </form>
                                <form method="post" asp-page-handler="Reject">
                                    <input type="hidden" name="id" value="@buyer.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger">@L["Action.Reject"]</button>
                                </form>
                            </div>
                        }
                        <form method="post" asp-page-handler="Delete" class="mt-1">
                            <input type="hidden" name="id" value="@buyer.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-danger">@L["Common.Delete"]</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
