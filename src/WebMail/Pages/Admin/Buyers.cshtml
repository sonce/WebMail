@page
@using WebMail.Domain
@model WebMail.Pages.Admin.BuyersModel
@{
    ViewData["Title"] = L["Admin.Buyers.Title"].Value;
    // 局部视图 _AdminBuyerTable 通过 ViewData 读取供应商下拉与指派映射。
    ViewData["AdminSuppliers"] = Model.Suppliers;
    ViewData["AdminAssignments"] = Model.AssignmentByBuyer;
    ViewData["AdminEmails"] = Model.EmailByBuyer;
    var unprocessed = Model.Buyers.Where(b => b.SupplierStatus == SupplierProcessingStatus.Unprocessed).ToList();
    var failed = Model.Buyers.Where(b => b.SupplierStatus == SupplierProcessingStatus.Failed).ToList();
    var completed = Model.Buyers.Where(b => b.SupplierStatus == SupplierProcessingStatus.Completed).ToList();
}

<h1 class="display-6">@L["Admin.Buyers.Title"]</h1>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-info" role="alert">@Model.Message</div>
}

<form method="get" class="row g-2 mb-3">
    <div class="col-12 col-sm-auto">
        <select class="form-select" asp-for="StageFilter"
                asp-items="Html.GetEnumSelectList<WebMail.Domain.BuyerStage>()">
            <option value="">@L["Filter.AllStage"]</option>
        </select>
    </div>
    <div class="col-12 col-sm-auto">
        <select class="form-select" asp-for="ReviewFilter"
                asp-items="Html.GetEnumSelectList<WebMail.Domain.ReviewStatus>()">
            <option value="">@L["Filter.AllReviewStatus"]</option>
        </select>
    </div>
    <div class="col-12 col-sm-auto">
        <select class="form-select" asp-for="EmailFilter"
                asp-items="Html.GetEnumSelectList<WebMail.Domain.EmailAuthorizationStatus>()">
            <option value="">@L["Filter.AllEmailStatus"]</option>
        </select>
    </div>
    <div class="col-12 col-sm-auto">
        <input class="form-control" asp-for="CardNo" placeholder="@L["Filter.CardKeyword"]" />
    </div>
    <div class="col-12 col-sm-auto">
        <button type="submit" class="btn btn-outline-primary">@L["Common.Filter"]</button>
        <a class="btn btn-outline-secondary" asp-page="/Admin/Buyers">@L["Common.Reset"]</a>
    </div>
</form>

<ul class="nav nav-tabs" id="adminBuyerTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="unprocessed-tab" data-bs-toggle="tab"
                data-bs-target="#unprocessed-pane" type="button" role="tab">@L["Supplier.Tab.Unprocessed"] (@unprocessed.Count)</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="failed-tab" data-bs-toggle="tab"
                data-bs-target="#failed-pane" type="button" role="tab">@L["Supplier.Tab.Failed"] (@failed.Count)</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="completed-tab" data-bs-toggle="tab"
                data-bs-target="#completed-pane" type="button" role="tab">@L["Supplier.Tab.Completed"] (@completed.Count)</button>
    </li>
</ul>
<div class="tab-content pt-3">
    <div class="tab-pane fade show active" id="unprocessed-pane" role="tabpanel" aria-labelledby="unprocessed-tab">
        <partial name="_AdminBuyerTable" model="unprocessed" />
    </div>
    <div class="tab-pane fade" id="failed-pane" role="tabpanel" aria-labelledby="failed-tab">
        <partial name="_AdminBuyerTable" model="failed" />
    </div>
    <div class="tab-pane fade" id="completed-pane" role="tabpanel" aria-labelledby="completed-tab">
        <partial name="_AdminBuyerTable" model="completed" />
    </div>
</div>

@section Scripts {
    <script>
        var copiedIcon = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">' +
            '<path d="M13.485 1.431a1.473 1.473 0 0 1 2.104 2.062l-7.84 9.801a1.473 1.473 0 0 1-2.12.04L.431 8.138a1.473 1.473 0 0 1 2.084-2.083l4.111 4.112 6.82-8.69a.486.486 0 0 1 .04-.045z"/></svg>';

        document.querySelectorAll('.copy-link').forEach(function (btn) {
            var original = btn.innerHTML;
            var timer = null;
            btn.addEventListener('click', function () {
                navigator.clipboard.writeText(btn.getAttribute('data-link'));
                btn.innerHTML = copiedIcon;
                btn.classList.add('copied');
                if (timer) { clearTimeout(timer); }
                timer = setTimeout(function () {
                    btn.innerHTML = original;
                    btn.classList.remove('copied');
                    timer = null;
                }, 1500);
            });
        });

        document.querySelectorAll('.copy-email').forEach(function (btn) {
            var timer = null;
            btn.addEventListener('click', function () {
                navigator.clipboard.writeText(btn.getAttribute('data-email'));
                btn.querySelector('.copy-email-icon').classList.add('d-none');
                btn.querySelector('.copy-email-check').classList.remove('d-none');
                btn.classList.add('copied');
                if (timer) { clearTimeout(timer); }
                timer = setTimeout(function () {
                    btn.querySelector('.copy-email-icon').classList.remove('d-none');
                    btn.querySelector('.copy-email-check').classList.add('d-none');
                    btn.classList.remove('copied');
                    timer = null;
                }, 1200);
            });
        });
    </script>
    <script>
        document.querySelectorAll('.supplier-edit').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var td = btn.closest('td');
                td.querySelector('.supplier-display').classList.add('d-none');
                td.querySelector('.supplier-form').classList.remove('d-none');
            });
        });
        document.querySelectorAll('.supplier-cancel').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var td = btn.closest('td');
                td.querySelector('.supplier-form').classList.add('d-none');
                td.querySelector('.supplier-display').classList.remove('d-none');
            });
        });
    </script>
}
