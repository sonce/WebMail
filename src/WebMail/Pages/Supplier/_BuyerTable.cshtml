@using WebMail.Domain
@model IReadOnlyList<Buyer>
@{
    // 列表已按状态筛选，同 tab 内所有买家 SupplierStatus 一致；空列表无按钮，回退 Unprocessed 即可。
    var activeStatus = Model.Count > 0 ? Model[0].SupplierStatus : SupplierProcessingStatus.Unprocessed;
    // 未处理 tab：标记失败 + 标记完成
    // 失败 tab：标记未处理 + 标记完成
    // 完成 tab：标记未处理 + 标记失败
    var showReset = activeStatus != SupplierProcessingStatus.Unprocessed;
    var showFailed = activeStatus != SupplierProcessingStatus.Failed;
    var showCompleted = activeStatus != SupplierProcessingStatus.Completed;
}

@if (Model.Count == 0)
{
    <p>@L["Common.NoBuyers"]</p>
}
else
{
    <div class="table-responsive">
    <table class="table table-striped table-cards">
        <thead>
            <tr>
                <th>@L["Table.CardNo"]</th>
                <th>@L["Table.EmailStatus"]</th>
                <th>@L["Table.Stage"]</th>
                <th>@L["Table.ReviewStatus"]</th>
                <th>@L["Table.SupplierStatus"]</th>
                <th>@L["Table.Operations"]</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var buyer in Model)
            {
                var link = $"{Context.Request.Scheme}://{Context.Request.Host}/?card={buyer.CardNo}";
                if (buyer.SaleId is not null)
                {
                    link += $"&saleid={buyer.SaleId}";
                }
                <tr>
                    <td data-label="@L["Table.CardNo"]" class="td-cardno">
                        <div class="cardno-cell">
                            <span class="cardno-text" title="@buyer.CardNo">@buyer.CardNo</span>
                            <button type="button" class="btn btn-sm btn-link p-0 copy-link"
                                    data-link="@link" title="@L["CardKey.CopyLink"]" aria-label="@L["CardKey.CopyLink"]">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M4 1.5H3a2 2 0 0 0-2 2V14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V3.5a2 2 0 0 0-2-2h-1v1h1a1 1 0 0 1 1 1V14a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1V3.5a1 1 0 0 1 1-1h1z"/>
                                    <path d="M9.5 1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-3a.5.5 0 0 1-.5-.5v-1a.5.5 0 0 1 .5-.5zm-3-1A1.5 1.5 0 0 0 5 1.5v1A1.5 1.5 0 0 0 6.5 4h3A1.5 1.5 0 0 0 11 2.5v-1A1.5 1.5 0 0 0 9.5 0z"/>
                                </svg>
                            </button>
                        </div>
                    </td>
                    <td data-label="@L["Table.EmailStatus"]">@buyer.EmailStatus</td>
                    <td data-label="@L["Table.Stage"]">@buyer.Stage</td>
                    <partial name="_ReviewStatusCell" model="buyer" />
                    <td data-label="@L["Table.SupplierStatus"]"><partial name="_SupplierStatusBadge" model="buyer.SupplierStatus" /></td>
                    <td data-label="@L["Table.Operations"]" class="td-actions">
                        <div class="d-flex gap-2 flex-wrap">
                            <a class="btn btn-sm btn-primary" asp-page="/Supplier/Mail" asp-route-buyerId="@buyer.Id">@L["Action.ViewMail"]</a>
                            @if (showReset)
                            {
                                <form method="post" asp-page-handler="SetStatus">
                                    <input type="hidden" name="buyerId" value="@buyer.Id" />
                                    <input type="hidden" name="status" value="@SupplierProcessingStatus.Unprocessed" />
                                    <button type="submit" class="btn btn-sm btn-outline-secondary">@L["Action.MarkUnprocessed"]</button>
                                </form>
                            }
                            @if (showFailed)
                            {
                                <form method="post" asp-page-handler="SetStatus">
                                    <input type="hidden" name="buyerId" value="@buyer.Id" />
                                    <input type="hidden" name="status" value="@SupplierProcessingStatus.Failed" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">@L["Action.MarkFailed"]</button>
                                </form>
                            }
                            @if (showCompleted)
                            {
                                <form method="post" asp-page-handler="SetStatus">
                                    <input type="hidden" name="buyerId" value="@buyer.Id" />
                                    <input type="hidden" name="status" value="@SupplierProcessingStatus.Completed" />
                                    <button type="submit" class="btn btn-sm btn-outline-success">@L["Action.MarkCompleted"]</button>
                                </form>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    </div>
}
