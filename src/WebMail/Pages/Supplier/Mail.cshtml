@page
@model WebMail.Pages.Supplier.MailModel
@{
    ViewData["Title"] = L["Supplier.Mail.Title"].Value;
}

<h1 class="display-6">@L["Supplier.Mail.Title"]</h1>

@if (!string.IsNullOrEmpty(Model.BuyerEmail))
{
    var email = Model.BuyerEmail;
    <p class="text-muted mb-3 d-flex align-items-center gap-1">
        <span>@L["Mail.BuyerEmail"]:</span>
        <button type="button" id="copyBuyerEmail" class="btn btn-sm btn-link p-0 copy-email d-inline-flex align-items-center gap-1"
                data-email="@email" title="@L["Action.CopyEmail"]" aria-label="@L["Action.CopyEmail"]">
            <span class="buyer-email-text text-dark">@email</span>
            <svg class="copy-email-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M0 4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v8a2 2 0 0 1-2 2H2a2 2 0 0 1-2-2V4zm2-1a1 1 0 0 0-1 1v.217l7 4.2 7-4.2V4a1 1 0 0 0-1-1H2zm13 2.383-4.708 2.825L15 11.105V5.383zM1 5.383v5.722l4.708-2.897L1 5.383zM2.242 13H13.758l-3.879-2.39-.79.474a.5.5 0 0 1-.516 0l-.79-.474L2.242 13z"/>
            </svg>
            <svg class="copy-email-check d-none" xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="#198754" viewBox="0 0 16 16">
                <path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6 10.293l6.646-6.647a.5.5 0 0 1 .708 0z"/>
            </svg>
        </button>
    </p>
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <div class="d-flex align-items-center gap-2">
        @if (User.IsInRole("Administrator"))
        {
            <a class="btn btn-secondary btn-sm" asp-page="/Admin/Buyers">@L["Common.BackToList"]</a>
        }
        else
        {
            <a class="btn btn-secondary btn-sm" asp-page="Buyers">@L["Common.BackToList"]</a>
        }
        @if (Model.IsEmailReady)
        {
            <button type="button" class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#addShipmentModal">
                @L["Action.AddShipment"]
            </button>
        }
    </div>
    @if (Model.IsEmailReady)
    {
        <div class="d-flex align-items-center gap-2">
            <label class="form-check-label mb-0">
                <input type="checkbox" id="autoPollToggle" checked /> @L["Mail.AutoPoll"]
            </label>
            <button type="button" class="btn btn-secondary btn-sm" id="refreshBtn">@L["Mail.Refresh"]</button>
        </div>
    }
</div>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-info">@Model.Message</div>
}

<div id="mailAlert" class="alert alert-warning d-none"></div>

@if (Model.IsEmailReady)
{
    <div class="mb-2">
        <input type="search" id="mailFilter" class="form-control form-control-sm" placeholder="@L["Mail.FilterPlaceholder"]" />
    </div>
}
else
{
    <div class="alert alert-warning">@L["Mail.NotAuthorized"]</div>
}

<div id="mailContent">
    @if (Model.IsEmailReady)
    {
        <p class="text-muted">@L["Mail.Loading"]</p>
    }
</div>

<div class="modal fade" id="mailDetailModal" tabindex="-1" aria-labelledby="mailDetailTitle" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="mailDetailTitle">@L["Mail.ContentTitle"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <dl class="row mb-3">
                    <dt class="col-sm-2">@L["Table.Sender"]</dt>
                    <dd class="col-sm-10" id="mailDetailSender"></dd>
                    <dt class="col-sm-2">@L["Table.Subject"]</dt>
                    <dd class="col-sm-10" id="mailDetailSubject"></dd>
                    <dt class="col-sm-2">@L["Table.SentAt"]</dt>
                    <dd class="col-sm-10" id="mailDetailSentAt"></dd>
                </dl>
                <iframe id="mailDetailHtml" class="mail-detail-frame d-none"
                        sandbox="allow-popups allow-popups-to-escape-sandbox"
                        title="@L["Mail.ContentTitle"]"></iframe>
                <pre id="mailDetailText" class="mail-detail-text d-none"></pre>
                <p id="mailDetailEmpty" class="text-muted d-none">@L["Mail.EmptyBody"]</p>
            </div>
        </div>
    </div>
</div>

<partial name="_ShipmentSection" model="Model" />

@section Scripts {
<script>
    (function () {
        var buyerId = @Model.BuyerId;
        var emailReady = @Model.IsEmailReady.ToString().ToLowerInvariant();
        var noMailText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Common.NoMail"].Value));
        var junkText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Mail.Junk"].Value));
        var refreshFailedText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Mail.RefreshFailed"].Value));
        var sourceText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Table.Type"].Value));
        var senderText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Table.Sender"].Value));
        var subjectText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Table.Subject"].Value));
        var sentAtText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Table.SentAt"].Value));
        var actionsText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Table.Actions"].Value));
        var viewText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Action.View"].Value));
        var refreshBtn = document.getElementById('refreshBtn');
        var refreshLabel = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Mail.Refresh"].Value));
        var fetchingLabel = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Mail.Fetching"].Value));
        var copyHintText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Mail.CopyNumberHint"].Value));
        var newMailText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Mail.NewMail"].Value));
        var newMailSummaryText = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(L["Mail.NewMailSummary"].Value));
        var pollUrl = '?handler=poll&buyerId=' + buyerId;
        var timer = null;
        var fetching = false;
        var currentMessages = {};
        // 已知邮件 id 集合：null 表示首次拉取尚未建立基线。用于跨轮询识别新邮件。
        var knownIds = null;

        function render(data) {
            var content = document.getElementById('mailContent');
            var alert = document.getElementById('mailAlert');
            var msgs = data.messages || [];
            notifyNewMail(msgs);
            currentMessages = {};
            for (var messageIndex = 0; messageIndex < msgs.length; messageIndex++) {
                currentMessages[msgs[messageIndex].id] = msgs[messageIndex];
            }

            if (data.stale || data.error) {
                alert.textContent = data.error || refreshFailedText;
                alert.classList.remove('d-none');
            } else {
                alert.classList.add('d-none');
            }

            if (msgs.length === 0) {
                content.innerHTML = '<p>' + noMailText + '</p>';
                return;
            }

            var rows = msgs.map(function (m) {
                var source = m.folder === 2 ? '<span class="badge bg-warning text-dark">' + junkText + '</span>' : '';
                return '<tr>'
                    + '<td data-label="' + sourceText + '">' + source + '</td>'
                    + '<td data-label="' + senderText + '" data-filter="' + escapeAttr(m.sender) + '">' + senderLink(m.sender) + '</td>'
                    + '<td class="td-subject" data-label="' + subjectText + '">' + highlightNumbers(m.subject) + '</td>'
                    + '<td data-label="' + sentAtText + '">' + formatSentAt(m.sentAt) + '</td>'
                    + '<td class="td-actions" data-label="' + actionsText + '"><button type="button" class="btn btn-outline-primary btn-sm view-mail-btn" data-message-id="' + escapeAttr(m.id) + '">' + viewText + '</button></td>'
                    + '</tr>';
            }).join('');

            content.innerHTML = '<div class="table-responsive"><table class="table table-striped table-cards">'
                + '<thead><tr><th>' + sourceText + '</th><th>' + senderText + '</th><th>' + subjectText + '</th><th>' + sentAtText + '</th><th>' + actionsText + '</th></tr></thead>'
                + '<tbody id="mailBody">' + rows + '</tbody></table></div>';
            applyFilter();
        }

        // 桌面通知：对比本次与上次已知的邮件 id，仅对新增的弹通知。首次拉取建立基线
        // 不通知；仅在页面不可见且已获授权时通知，避免用户正查看邮件页时重复打扰。
        function notifyNewMail(msgs) {
            if (!('Notification' in window)) { return; }
            if (knownIds === null) {
                knownIds = new Set(msgs.map(function (m) { return m.id; }));
                return;
            }
            var fresh = [];
            for (var i = 0; i < msgs.length; i++) {
                if (!knownIds.has(msgs[i].id)) { fresh.push(msgs[i]); knownIds.add(msgs[i].id); }
            }
            if (fresh.length === 0 || !document.hidden || Notification.permission !== 'granted') { return; }
            // 单封显示该邮件标题；多封只显示数量。
            var title = fresh.length === 1
                ? (fresh[0].subject || newMailText)
                : newMailSummaryText.replace('{0}', String(fresh.length));
            try {
                var n = new Notification(title);
                n.onclick = function () { window.focus(); n.close(); };
            } catch (e) { /* 部分环境构造通知可能抛错（如缺少图标），忽略以免阻塞渲染。*/ }
        }

        function applyFilter() {
            var term = (document.getElementById('mailFilter').value || '').trim().toLowerCase();
            var body = document.getElementById('mailBody');
            if (!body) { return; }
            var rows = body.querySelectorAll('tr');
            for (var i = 0; i < rows.length; i++) {
                // Match against the full sender (data-filter: name + address) so
                // filtering by email works even though only the name is visible.
                var senderCell = rows[i].cells[1];
                var subjectCell = rows[i].cells[2];
                var senderText = (senderCell && (senderCell.getAttribute('data-filter') || senderCell.textContent)) || '';
                var subjectText = (subjectCell && subjectCell.textContent) || '';
                var match = senderText.toLowerCase().indexOf(term) !== -1 || subjectText.toLowerCase().indexOf(term) !== -1;
                rows[i].style.display = match ? '' : 'none';
            }
        }

        function escapeHtml(s) {
            return String(s == null ? '' : s).replace(/[&<>"']/g, function (c) {
                return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
            });
        }

        function escapeAttr(s) {
            return String(s == null ? '' : s).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
        }

        // Highlight runs of 5+ digits in the subject as a clickable copy badge.
        // Non-digit segments are HTML-escaped; digit runs are wrapped and their raw
        // value stashed in data-copy for the click handler.
        function highlightNumbers(subject) {
            var s = String(subject == null ? '' : subject);
            var out = '', i = 0, n = s.length;
            while (i < n) {
                var digits = '';
                while (i < n && s.charAt(i) >= '0' && s.charAt(i) <= '9') {
                    digits += s.charAt(i);
                    i++;
                }
                if (digits.length >= 5) {
                    out += '<span class="mail-num-badge" data-copy="' + escapeAttr(digits) + '" title="' + copyHintText + '" role="button" tabindex="0">'
                        + '<span class="mail-num-text">' + escapeHtml(digits) + '</span>'
                        + '<span class="mail-num-icon">'
                        + '<svg class="mail-num-icon-copy" viewBox="0 0 16 16" width="13" height="13" aria-hidden="true"><path d="M4 1.5A1.5 1.5 0 0 1 5.5 0H11a1.5 1.5 0 0 1 1.5 1.5V4H11V1.5H5.5V13H11v-1.5h1.5V13A1.5 1.5 0 0 1 11 14.5H5.5A1.5 1.5 0 0 1 4 13V1.5z"/><path d="M6.5 3A1.5 1.5 0 0 0 5 4.5v10A1.5 1.5 0 0 0 6.5 16h6a1.5 1.5 0 0 0 1.5-1.5v-10A1.5 1.5 0 0 0 12.5 3h-6zm0 1.5h6v10h-6v-10z"/></svg>'
                        + '<svg class="mail-num-icon-check" viewBox="0 0 16 16" width="13" height="13" aria-hidden="true"><path d="M13.854 3.646a.5.5 0 0 1 0 .708l-7 7a.5.5 0 0 1-.708 0l-3.5-3.5a.5.5 0 1 1 .708-.708L6 10.293l6.646-6.647a.5.5 0 0 1 .708 0z"/></svg>'
                        + '</span>'
                        + '</span>';
                } else if (digits.length > 0) {
                    out += escapeHtml(digits);
                }
                var text = '';
                while (i < n && (s.charAt(i) < '0' || s.charAt(i) > '9')) {
                    text += s.charAt(i);
                    i++;
                }
                if (text.length > 0) {
                    out += escapeHtml(text);
                }
            }
            return out;
        }

        // Display the sender as a mailto link; show the address via tooltip. Falls back
        // to plain text when no parseable address is present. Handles "Name <addr>" and
        // bare "addr" forms.
        function senderLink(rawSender) {
            var s = String(rawSender == null ? '' : rawSender).trim();
            var lt = s.lastIndexOf('<'), gt = s.lastIndexOf('>');
            var email = '', name = '';
            if (lt !== -1 && gt !== -1 && gt > lt) {
                email = s.substring(lt + 1, gt).trim();
                name = s.substring(0, lt).trim();
            } else if (s.indexOf('@@') !== -1) {
                email = s;
            }
            var display = name || email || s;
            if (email) {
                return '<a href="mailto:' + escapeAttr(email) + '" title="' + escapeAttr(email) + '">' + escapeHtml(display) + '</a>';
            }
            return escapeHtml(display);
        }

        // Format the ISO timestamp as YYYY-MM-DD HH:MM:SS in local time.
        function formatSentAt(iso) {
            var d = new Date(iso);
            if (isNaN(d.getTime())) { return escapeHtml(iso); }
            var pad = function (n) { return n < 10 ? '0' + n : '' + n; };
            return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate())
                + ' ' + pad(d.getHours()) + ':' + pad(d.getMinutes()) + ':' + pad(d.getSeconds());
        }

        function fetchMail(force) {
            // Auto-poll skips when a fetch is already in flight, to avoid piling up
            // requests. Manual refresh always proceeds and shows the busy state.
            if (!force && fetching) { return; }
            fetching = true;
            refreshBtn.disabled = true;
            refreshBtn.textContent = fetchingLabel;
            var done = function () {
                fetching = false;
                refreshBtn.disabled = false;
                refreshBtn.textContent = refreshLabel;
            };
            $.getJSON(pollUrl + (force ? '&force=true' : ''))
                .done(render)
                .fail(function () {
                    var alert = document.getElementById('mailAlert');
                    alert.textContent = refreshFailedText;
                    alert.classList.remove('d-none');
                })
                .always(done);
        }

        function startTimer() { stopTimer(); timer = setInterval(function () { fetchMail(false); }, 15000); }
        function stopTimer() { if (timer) { clearInterval(timer); timer = null; } }

        if (emailReady) {
            refreshBtn.addEventListener('click', function () { fetchMail(true); });
            document.getElementById('autoPollToggle').addEventListener('change', function () {
                if (this.checked) { startTimer(); } else { stopTimer(); }
            });
            document.getElementById('mailFilter').addEventListener('input', applyFilter);
            // 浏览器要求在用户手势内请求通知权限；在首次交互（点击/按键）时请求一次。
            if ('Notification' in window && Notification.permission === 'default') {
                var requestNotifyOnce = function () {
                    document.removeEventListener('pointerdown', requestNotifyOnce);
                    document.removeEventListener('keydown', requestNotifyOnce);
                    Notification.requestPermission();
                };
                document.addEventListener('pointerdown', requestNotifyOnce);
                document.addEventListener('keydown', requestNotifyOnce);
            }
        }
        // Copy the number when its badge is clicked/activated (text or icon both
        // trigger it; delegated so it survives re-renders).
        function copyNumber(badge) {
            var value = badge.getAttribute('data-copy') || '';
            var showCopied = function () {
                badge.classList.add('copied');
                setTimeout(function () { badge.classList.remove('copied'); }, 1200);
            };
            if (navigator.clipboard && navigator.clipboard.writeText) {
                navigator.clipboard.writeText(value).then(showCopied).catch(showCopied);
            } else {
                var ta = document.createElement('textarea');
                ta.value = value;
                document.body.appendChild(ta);
                ta.select();
                try { document.execCommand('copy'); } catch (err) {}
                document.body.removeChild(ta);
                showCopied();
            }
        }
        document.getElementById('mailContent').addEventListener('click', function (e) {
            var viewButton = e.target.closest('.view-mail-btn');
            if (viewButton) {
                showMailDetail(currentMessages[viewButton.getAttribute('data-message-id')]);
                return;
            }
            var badge = e.target.closest('.mail-num-badge');
            if (!badge) { return; }
            copyNumber(badge);
        });

        function showMailDetail(message) {
            if (!message) { return; }
            document.getElementById('mailDetailSender').textContent = message.sender || '';
            document.getElementById('mailDetailSubject').textContent = message.subject || '';
            document.getElementById('mailDetailSentAt').textContent = formatSentAt(message.sentAt);

            var htmlFrame = document.getElementById('mailDetailHtml');
            var textBody = document.getElementById('mailDetailText');
            var emptyBody = document.getElementById('mailDetailEmpty');
            htmlFrame.classList.add('d-none');
            textBody.classList.add('d-none');
            emptyBody.classList.add('d-none');
            htmlFrame.removeAttribute('srcdoc');
            textBody.textContent = '';

            if (message.htmlBody) {
                htmlFrame.srcdoc = prepareHtmlBody(message.htmlBody);
                htmlFrame.classList.remove('d-none');
            } else if (message.textBody) {
                textBody.textContent = message.textBody;
                textBody.classList.remove('d-none');
            } else {
                emptyBody.classList.remove('d-none');
            }

            bootstrap.Modal.getOrCreateInstance(document.getElementById('mailDetailModal')).show();
        }

        function prepareHtmlBody(html) {
            var documentNode = new DOMParser().parseFromString(html, 'text/html');
            var base = documentNode.createElement('base');
            base.target = '_blank';
            documentNode.head.prepend(base);
            return documentNode.documentElement.outerHTML;
        }
        document.getElementById('mailContent').addEventListener('keydown', function (e) {
            if (e.key !== 'Enter' && e.key !== ' ') { return; }
            var badge = e.target.closest('.mail-num-badge');
            if (!badge) { return; }
            e.preventDefault();
            copyNumber(badge);
        });
        window.addEventListener('beforeunload', stopTimer);

        // 复制买家邮箱地址：点击邮箱文本即复制，信封图标切换为对勾反馈。
        var emailBtn = document.getElementById('copyBuyerEmail');
        if (emailBtn) {
            emailBtn.addEventListener('click', function () {
                var value = emailBtn.getAttribute('data-email') || '';
                var showCopied = function () {
                    emailBtn.querySelector('.copy-email-icon').classList.add('d-none');
                    emailBtn.querySelector('.copy-email-check').classList.remove('d-none');
                    setTimeout(function () {
                        emailBtn.querySelector('.copy-email-icon').classList.remove('d-none');
                        emailBtn.querySelector('.copy-email-check').classList.add('d-none');
                    }, 1200);
                };
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(value).then(showCopied).catch(showCopied);
                } else {
                    var ta = document.createElement('textarea');
                    ta.value = value;
                    document.body.appendChild(ta);
                    ta.select();
                    try { document.execCommand('copy'); } catch (err) {}
                    document.body.removeChild(ta);
                    showCopied();
                }
            });
        }

        // 未授权时不获取邮件；仅在邮箱就绪时发起首次拉取并启动自动轮询。
        if (emailReady) {
            fetchMail(false);
            if (document.getElementById('autoPollToggle').checked) { startTimer(); }
        }
    })();
</script>
}
