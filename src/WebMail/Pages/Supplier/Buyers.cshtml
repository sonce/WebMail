@page
@using WebMail.Domain
@model WebMail.Pages.Supplier.BuyersModel
@{
    ViewData["Title"] = L["Supplier.Buyers.Title"].Value;
    var unprocessed = Model.Buyers.Where(r => r.Buyer.SupplierStatus == SupplierProcessingStatus.Unprocessed).ToList();
    var failed = Model.Buyers.Where(r => r.Buyer.SupplierStatus == SupplierProcessingStatus.Failed).ToList();
    var completed = Model.Buyers.Where(r => r.Buyer.SupplierStatus == SupplierProcessingStatus.Completed).ToList();
}

<h1 class="display-6">@L["Supplier.Buyers.Title"]</h1>

@if (!string.IsNullOrEmpty(Model.Message))
{
    <div class="alert alert-info" role="alert">@Model.Message</div>
}

<ul class="nav nav-tabs" id="supplierBuyerTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="unprocessed-tab" data-bs-toggle="tab"
                data-bs-target="#unprocessed-pane" type="button" role="tab">@L["Supplier.Tab.Unprocessed"] (@unprocessed.Count)</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="failed-tab" data-bs-toggle="tab"
                data-bs-target="#failed-pane" type="button" role="tab">@L["Supplier.Tab.Failed"] (@failed.Count)</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="completed-tab" data-bs-toggle="tab"
                data-bs-target="#completed-pane" type="button" role="tab">@L["Supplier.Tab.Completed"] (@completed.Count)</button>
    </li>
</ul>
<div class="tab-content pt-3">
    <div class="tab-pane fade show active" id="unprocessed-pane" role="tabpanel" aria-labelledby="unprocessed-tab">
        <partial name="_BuyerTable" model="unprocessed" />
    </div>
    <div class="tab-pane fade" id="failed-pane" role="tabpanel" aria-labelledby="failed-tab">
        <partial name="_BuyerTable" model="failed" />
    </div>
    <div class="tab-pane fade" id="completed-pane" role="tabpanel" aria-labelledby="completed-tab">
        <partial name="_BuyerTable" model="completed" />
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.copy-email').forEach(function (btn) {
            var timer = null;
            btn.addEventListener('click', function () {
                navigator.clipboard.writeText(btn.getAttribute('data-email'));
                btn.querySelector('.copy-email-icon').classList.add('d-none');
                btn.querySelector('.copy-email-check').classList.remove('d-none');
                btn.classList.add('copied');
                if (timer) { clearTimeout(timer); }
                timer = setTimeout(function () {
                    btn.querySelector('.copy-email-icon').classList.remove('d-none');
                    btn.querySelector('.copy-email-check').classList.add('d-none');
                    btn.classList.remove('copied');
                    timer = null;
                }, 1200);
            });
        });
    </script>
}
