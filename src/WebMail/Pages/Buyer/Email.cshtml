@page
@using WebMail.Domain
@using WebMail.Services
@model WebMail.Pages.Buyer.EmailModel
@{
    ViewData["Title"] = L["Buyer.Email.Title"].Value;
}

<h1 class="display-6">@L["Buyer.Email.Title"]</h1>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-warning" role="alert">@Model.ErrorMessage</div>
}

@if (!string.IsNullOrEmpty(Model.Card))
{
    <dl class="row">
        <dt class="col-sm-3">@L["Buyer.Email.Stage"]</dt>
        <dd class="col-sm-9">@Model.Stage</dd>
        <dt class="col-sm-3">@L["Table.EmailStatus"]</dt>
        <dd class="col-sm-9">@Model.EmailStatus</dd>
        <dt class="col-sm-3">@L["Table.ReviewStatus"]</dt>
        <dd class="col-sm-9">@Model.ReviewStatus</dd>
        <dt class="col-sm-3">@L["Table.SupplierStatus"]</dt>
        <dd class="col-sm-9">@Model.SupplierStatus</dd>
    </dl>

    @if (Model.EmailAccount is not null)
    {
        <p><strong>@L["Buyer.Email.BoundEmail"]</strong>@Model.EmailAccount.Email</p>
    }

    <div class="d-flex gap-2 flex-wrap actions-stack">
        @if (Model.Actions.HasFlag(BuyerMailAction.Authorize))
        {
            <a class="btn btn-primary" asp-page="/OAuth/Start" asp-route-provider="Gmail" asp-route-card="@Model.Card">@L["Action.AuthorizeGmail"]</a>
            <a class="btn btn-outline-primary" asp-page="/OAuth/Start" asp-route-provider="Outlook" asp-route-card="@Model.Card">@L["Action.AuthorizeOutlook"]</a>
        }
        @if (Model.Actions.HasFlag(BuyerMailAction.ReAuthorize) && Model.EmailAccount is not null)
        {
            <a class="btn btn-warning" asp-page="/OAuth/Start" asp-route-provider="@Model.EmailAccount.Provider" asp-route-card="@Model.Card">@L["Action.ReAuthorize"]</a>
        }
        @if (Model.Actions.HasFlag(BuyerMailAction.ChangeEmail))
        {
            <form method="post" asp-page-handler="ChangeEmail">
                <input type="hidden" name="card" value="@Model.Card" />
                <button type="submit" class="btn btn-secondary">@L["Action.ChangeEmail"]</button>
            </form>
        }
        @if (Model.Actions.HasFlag(BuyerMailAction.ClearAuth))
        {
            <form method="post" asp-page-handler="ClearAuth">
                <input type="hidden" name="card" value="@Model.Card" />
                <button type="submit" class="btn btn-danger">@L["Action.ClearAuth"]</button>
            </form>
        }
    </div>

    @if (Model.Actions == BuyerMailAction.None)
    {
        <div class="alert alert-info mt-2" role="alert">@L["Buyer.Email.NoActions"]</div>
    }
}
