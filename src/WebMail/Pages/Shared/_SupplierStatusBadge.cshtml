@using WebMail.Domain
@model SupplierProcessingStatus

@switch (Model)
{
    case SupplierProcessingStatus.Failed:
        <span class="badge bg-danger">@L["Supplier.Status.Failed"]</span>
        break;
    case SupplierProcessingStatus.Completed:
        <span class="badge bg-success">@L["Supplier.Status.Completed"]</span>
        break;
    default:
        <span>@L["Supplier.Status.Unprocessed"]</span>
        break;
}
