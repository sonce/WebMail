# Copy to .env and fill in real values. Do NOT commit .env.
#
# These are the variables referenced by docker-compose.yml.
GOOGLE_CLIENT_SECRET=
OUTLOOK_CLIENT_SECRET=
ADMIN_PASSWORD=Admin@123
# Public base URL; must match one of your registered OAuth callback hosts.
WEBMAIL_PUBLIC_BASE_URL=https://webmail.example
# Hostname traefik routes on (must resolve to this server). Keep in sync with
# WEBMAIL_PUBLIC_BASE_URL and the OAuth registered callback host.
WEBMAIL_HOST=webmail.example

# Optional overrides (MailSync tuning, admin username, Google redirect URI, etc.)
# have built-in defaults in appsettings.json. To override one, add an env var
# here AND a matching `Key: "${VAR}"` line under environment: in docker-compose.yml.
